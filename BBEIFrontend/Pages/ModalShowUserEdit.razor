                    <label>
                        User's phone number:
                        +39 <input type="text" disabled="@controlsDisabled" @bind="userPhoneNumber" pattern="?[0-9]" />
                    </label>
                </div>
                <div>

                    <label>Role:</label>

                    <label>
                        <input type="radio" disabled="@controlsDisabled" name="role" value=USER checked="@isUser" @onchange="() => HandleRadioButtonChange(USER)">
                        @USER
                    </label>

                    @if (string.Compare(masterUser.Role, "MANTAINER", true) == 0)
                    {

                        //Mantainer, può rimanere mantainer o downgradare a user
                        <label>
                            &nbsp; &nbsp; &nbsp;
                            <input type="radio" disabled="@controlsDisabled" name="role" value=MANTAINER checked="@isMantainer" @onchange="() => HandleRadioButtonChange(MANTAINER)">
                            @MANTAINER
                        </label>

                    }
                    else if (string.Compare(masterUser.Role, "ADMIN", true) == 0)
                    {
                        //Amministratore, può rimanere admin o downgradare a maintainer o user
                        <label>
                            &nbsp; &nbsp; &nbsp;
                            <input type="radio" disabled="@controlsDisabled" name="role" value=MANTAINER checked="@isMantainer" @onchange="() => HandleRadioButtonChange(MANTAINER)">
                            @MANTAINER
                        </label>
                        <label>
                            &nbsp; &nbsp; &nbsp;
                            <input type="radio" disabled="@controlsDisabled" name="role" value=ADMIN checked="@isAdmin" @onchange="() => HandleRadioButtonChange(ADMIN)">
                            @ADMIN
                        </label>

                    }
                </div>
                <div>
                    <table class="btnTable">
                        <thead>
                            <tr>
                                <th>
                                    <AuthorizeView Roles="ADMIN, MANTAINER">
                                        <Authorized>
                                            <button class="btn-menu btn_blue" @onclick="ModifyUser"><span>APPLY<br>MODIFICATIONS</span></button>
                                        </Authorized>
                                    </AuthorizeView>
                                </th>
                                <th>
                                    <AuthorizeView Roles="ADMIN, MANTAINER">
                                        <Authorized>
                                            <button class="btn-menu btn_blue" @onclick="DeleteUser"><span>DELETE<br>USER</span></button>
                                        </Authorized>
                                    </AuthorizeView>
                                </th>
                                <th>

                                </th>
                                <th>

                                </th>
                                <th>

                                </th>
                                <th>

                                </th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        }
    </div>
</div>



@code {
