        <h4>Edit user</h4>
        <br />
        @* <h1>
        @if (owner != null)
        {
        @owner.Identity.Name;
        }
        </h1> *@
        @if (user != null)
        {
            <div>
                <div>
                    <label>
                        User's email:
                        <input type="text" disabled="true" @bind="userEmail" @oninput="HandleUserEmailInput" />
                    </label>
                </div>
                <div>
                    <label>
                        User's password:
