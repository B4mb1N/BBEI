    {

        if (role == USER)
        {
            isUser = true;
            isMantainer = false;
            isAdmin = false;
        }
        else if (role == MANTAINER)
        {
            isUser = false;
            isMantainer = true;
            isAdmin = false;
        }
        else if (role == ADMIN)
        {
            isUser = false;
            isMantainer = false;
            isAdmin = true;
        }

