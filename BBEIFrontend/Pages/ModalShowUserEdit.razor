    private async Task ModifyUser()
    {
        //freeze dei controlli
        controlsDisabled = true;

        try
        {

            await Task.Delay(1);

            //Controllo del cambiamento eventuali parametri
            string newMail = "";
            string newPassword = "";
            string newRole = "";
            bool authorizeChanges = true;

            if (string.Compare(userEmail, user.UserName, true) != 0)
            {
                if (IsValidEmail(userEmail))
                {
                    newMail = userEmail;
                }
                else
                {
                    JsRuntime.InvokeVoidAsync("alert", "Email does not seem to be valid - please check back!"); // Alert
                    authorizeChanges = false;
                }
            }

            if (!string.IsNullOrEmpty(userSecEmail) && !IsValidEmail(userSecEmail))
                authorizeChanges = false;

            if (!string.IsNullOrEmpty(userPassword))
            {
                newPassword = userPassword;
            }

            string roleString = "";
            if (isUser)
            {
                roleString = USER;
            }
            else if (isMantainer)
            {
                roleString = MANTAINER;
            }
            else if (isAdmin)
            {
                roleString = ADMIN;
            }

            if (string.Compare(roleString, user.Role, true) != 0)
            {
                newRole = roleString;
            }

            if (authorizeChanges)
            {
                Task<bool> updateTask = Task.Run(() => gestoreDb.SRMUserUpdate(UserManager, user.UserName, newMail, newPassword, newRole, userSecEmail, userPhoneNumber, userFullName));
                Task.WaitAll(updateTask);

                if (updateTask != null)
                {
                    if (updateTask.Result)
                    {
                        JsRuntime.InvokeVoidAsync("alert", "Update ok!"); // Alert
                        CloseModal();
                    }
                    else
                    {
                        JsRuntime.InvokeVoidAsync("alert", "Update failed!"); // Alert
                    }
                }
                else
                {
                    JsRuntime.InvokeVoidAsync("alert", "Update failed!"); // Alert
                }

            }


        }
        catch (Exception ex)
        {
            Log.Error("Add user page AddUser error: " + ex.Message);
        }

        //scongelamento dei controlli
        controlsDisabled = false;
        //Richiedi l'aggiornamento del componente
        StateHasChanged();
        await OnSave.InvokeAsync();
    }

    private async Task DeleteUser()
    {
        //freeze dei controlli
        controlsDisabled = true;
        try
        {

            if (string.Compare(masterUser.UserName, user.UserName, true) != 0)
            {
                //Inserire check su yes/no
                bool confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure want to delete " + user.UserName + "?"); // Confirm

                if (confirmed)
                {

                    Task<bool> deleteTask = Task.Run(() => gestoreDb.SRMUserDelete(UserManager, user.UserName));
                    Task.WaitAll(deleteTask);

                    if (deleteTask != null)
                    {
                        if (deleteTask.Result)
                        {
                            JsRuntime.InvokeVoidAsync("alert", userEmail + " deleted correctly."); // Alert
                            CloseModal();
                        }
                        else
                        {
                            JsRuntime.InvokeVoidAsync("alert", userEmail + " deletion failed!"); // Alert
                        }
                    }
                    else
                    {
                        JsRuntime.InvokeVoidAsync("alert", "deletion failed!"); // Alert
                    }

                    await Task.Delay(1);
                }
            }
            else
            {
                JsRuntime.InvokeVoidAsync("alert", "Can't delete logged user/self!"); // Alert
            }

        }
        catch (Exception ex)
        {
            Log.Error("Add user page DeleteUser error: " + ex.Message);
        }

        //scongelamento dei controlli
        controlsDisabled = false;
        //Richiedi l'aggiornamento del componente
        StateHasChanged();
        await OnSave.InvokeAsync();
    }

    private bool IsValidEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return false;

        try
        {
            // Normalize the domain
            email = Regex.Replace(email, @"(@)(.+)$", DomainMapper,
                                  RegexOptions.None, TimeSpan.FromMilliseconds(200));

            // Examines the domain part of the email and normalizes it.
            string DomainMapper(Match match)
            {
                // Use IdnMapping class to convert Unicode domain names.
                var idn = new IdnMapping();

                // Pull out and process domain name (throws ArgumentException on invalid)
                string domainName = idn.GetAscii(match.Groups[2].Value);

                return match.Groups[1].Value + domainName;
            }
        }
        catch (RegexMatchTimeoutException e)
        {
            return false;
        }
        catch (ArgumentException e)
        {
            return false;
        }

        try
        {
            return Regex.IsMatch(email,
                @"^[^@\s]+@[^@\s]+\.[^@\s]+$",
                RegexOptions.IgnoreCase, TimeSpan.FromMilliseconds(250));
        }
        catch (RegexMatchTimeoutException)
        {
            return false;
        }
    }

    private string GenerateRandomPassword(int length)
    {
        string[] randomChars = new[] {
            "ABCDEFGHJKLMNOPQRSTUVWXYZ",    // uppercase
            "abcdefghijkmnopqrstuvwxyz",    // lowercase
            "0123456789",                   // digits
            "!@#$%^&*()_-+=<>?"                        // non-alphanumeric
        };

        Random rand = new Random(Environment.TickCount);
        List<char> chars = new List<char>();


        chars.Insert(rand.Next(0, chars.Count),
            randomChars[0][rand.Next(0, randomChars[0].Length)]);


        chars.Insert(rand.Next(0, chars.Count),
            randomChars[1][rand.Next(0, randomChars[1].Length)]);


        chars.Insert(rand.Next(0, chars.Count),
            randomChars[2][rand.Next(0, randomChars[2].Length)]);


        chars.Insert(rand.Next(0, chars.Count),
            randomChars[3][rand.Next(0, randomChars[3].Length)]);

        for (int i = chars.Count; i < length
            || chars.Distinct().Count() < 5; i++)
        {
            string rcs = randomChars[rand.Next(0, randomChars.Length)];
            chars.Insert(rand.Next(0, chars.Count),
                rcs[rand.Next(0, rcs.Length)]);
        }

        string password = new string(chars.ToArray());

        return password;
    }

    private void CompileNewPassword()
    {
        try
        {
            userPassword = GenerateRandomPassword(10);
            StateHasChanged();

        }
        catch (Exception ex)
        {
            Log.Error("Add user page CompileNewPassword error: " + ex.Message);
        }
    }

