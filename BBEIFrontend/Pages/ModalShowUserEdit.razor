    private string userEmail { get; set; } = "";
    private string userSecEmail { get; set; } = "";
    private string userPhoneNumber { get; set; } = "";
    private string userFullName { get; set; } = "";
    private string userPassword { get; set; } = "";
    private GestoreDb? gestoreDb;

    private bool IsModalOpen = false;

    private const string USER = "USER";
    private const string MANTAINER = "MANTAINER";
    private const string ADMIN = "ADMIN";

    private bool controlsDisabled;

    @inject IJSRuntime JsRuntime

    public void ShowModal(UserInfo myUser, UserInfo myMasterUser)
    {
        IsModalOpen = true;
        user = myUser;
        masterUser = myMasterUser;
        isUser = true;
        isMantainer = false;
        isAdmin = false;
        userEmail = myUser.UserName;
        userSecEmail = myUser.SecondaryEmail;
        userFullName = myUser.Name;
        userPhoneNumber = myUser.PhoneNumber;
        userPassword = "";
        gestoreDb = new();
        controlsDisabled = false;
        List<string> customers = new List<string>();

        //controllo stato attuale dello user
        if (user.Role == "ADMIN")
        {
            isAdmin = true;
            isMantainer = false;
            isUser = false;
        }
        else if (user.Role == "MANTAINER")
        {
            isAdmin = false;
            isMantainer = true;
            isUser = false;
        }
        else if (user.Role == "USER")
        {
            isAdmin = false;
            isMantainer = false;
            isUser = true;
        }


        StateHasChanged();
    }

    public void CloseModal()
    {
        IsModalOpen = false;
        user = null;
        masterUser = null;
        isUser = true;
        isMantainer = false;
        isAdmin = false;
        userEmail = "";
        userSecEmail = "";
        userPhoneNumber = "";
        userFullName = "";
        userPassword = "";
        gestoreDb = null;
        controlsDisabled = false;
        StateHasChanged();
    }

