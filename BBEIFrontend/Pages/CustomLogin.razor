@page "/login"
@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations
@using BBEIDataAccess;
@using System.Security.Claims;
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider


<div class="content px-4">
    <h3>BBEI Login Page</h3>

    <p>Please enter your credentials:</p>

    <EditForm EditContext="editContext" OnSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="InputUserName">Username</label>
            <InputText id="InputUserName" style="width: 250px;" class="form-control" @bind-Value="@model.Username" type="text" name="username" formcontrolname="username" autocomplete="on" />
            <ValidationMessage For="@(() => model.Username)" />
        </div>

        <div class="form-group">
            <label for="InputPassword">Password</label>
            <InputText id="InputPassword" style="width: 250px;" class="form-control" @bind-Value="@model.Password" type="password" name="password" formcontrolname="password" autocomplete="on" />
            <ValidationMessage For="@(() => model.Password)" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">@errorMessage</div>
        }

        <br />
        <button type="submit" class="btn btn-success">Login</button>
    </EditForm>
</div>

<ModalShowFirstAccessChangePwd @ref="modalShowFirstAccessChangePwd" />

@code {
    private MyModel model = new MyModel();
    private EditContext editContext;
    private ModalShowFirstAccessChangePwd? modalShowFirstAccessChangePwd;
    private string errorMessage;

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (editContext.Validate())
            {

                Task<ApplicationUser> userTask = Task.Run(() => UserManager.FindByNameAsync(model.Username));
                Task.WaitAll(userTask);

                ApplicationUser user = userTask.Result;

                if (user == null)
                    errorMessage = "Wrong username or wrong password";
                else
                {
                    if (!await SignInManager.CanSignInAsync(user))
                    {
                        errorMessage = "Your account is blocked";
                    }
                    else
                    {
                        if (!user.EmailConfirmed)
                        {
                            //Controllo di consistenza della password
                            var result = await SignInManager.CheckPasswordSignInAsync(user, model.Password, false);

                            if (result.Succeeded)
                            {
                                //Primo accesso di un utente non di sistema, deve obbligatoriamente cambiare la pwd
                                //Mostro cambio password e poi sbianco i campi x il login
                                modalShowFirstAccessChangePwd.ShowModal(user, model.Password);
                                NavigationManager.NavigateTo("/login");
                            }
                            else
                            {
                                errorMessage = "Username or password is incorrect";
                            }
                        }
                        else
                        {
                            var result = await SignInManager.CheckPasswordSignInAsync(user, model.Password, false);

                            if (result.Succeeded)
                            {
                                //Autorizzo ed entro
                                Guid key = Guid.NewGuid();
                                BlazorCookieLoginMiddleware.Logins[key] = new LoginInfo { Username = model.Username, Password = model.Password };
                                NavigationManager.NavigateTo($"/login?key={key}", true);
                            }
                            else
                            {
                                errorMessage = "Username or password is incorrect";
                            }
                        }

                    }
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error raised: " + ex.Message;
        }
    }

    private class MyModel
    {
        [Required(ErrorMessage = "Username is required.")]
        public string Username { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; }
    }
}
